# DevOS 环境变量配置
# 复制为 .env 后修改

# 服务
SERVER_PORT=8080
SERVER_MODE=debug

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=devos
DB_PASSWORD=devos
DB_NAME=devos
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ACCESS_EXPIRE_MIN=30
JWT_REFRESH_EXPIRE_HR=168

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
